# Database Connection URI (MongoDB Atlas or Local MongoDB)
MONGODB_URI=your_mongodb_uri_here

# Backend Port
PORT=4000

# JSON Web Token Secret
JWT_SECRET=your_jwt_signing_secret_here

# Cloudinary Storage Configuration (For images and file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Gmail SMTP Email Configuration (For account verification OTPs)
SMTP_USER=your_smtp_user_email_here
SMTP_PASS=your_smtp_password_app_key_here

# Google Gemini API Key (Optional: For smart replies, translations, summaries, AI chat)
GEMINI_API_KEY=your_gemini_api_key_here
